{
  "name": "itour-tms",
  "version": "1.0.0",
  "private": true,
  "description": "iTourTMS — Enterprise Travel Management System",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
