    "autoprefixer": "^10.4.24",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.4.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.0",
