generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH MODELS (Auth.js v5)
// ============================================================================

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("Account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// COMPANY & TENANT
// ============================================================================

model Company {
  id              String   @id @default(cuid())
  name            String
  abbreviation    String?
  legalName       String?
  taxId           String?
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  faviconUrl      String?
  loginLogoUrl    String?
  sidebarLogoUrl  String?
  loginBgUrl      String?
  innerBgUrl      String?
  reportsLogoUrl  String?
  countryId       String?
  baseCurrencyId  String?
  fiscalYearStart Int      @default(1) // month 1-12
  fiscalYearEnd   Int      @default(12)
  timezone             String   @default("UTC")
  googlePlacesApiKey   String?
  hotelCodePrefix      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  country      Country?  @relation(fields: [countryId], references: [id])
  baseCurrency Currency? @relation(fields: [baseCurrencyId], references: [id])

  users             User[]
  roles             Role[]
  partners          Partner[]
  currencyRates     CurrencyRate[]
  sequences         Sequence[]
  installedModules  InstalledModule[]
  setup             CompanySetup?

  // Finance relations
  accountGroups     AccountGroup[]
  finAccounts       FinAccount[]
  journals          Journal[]
  taxes             Tax[]
  taxGroups         TaxGroup[]
  paymentTerms      PaymentTerm[]
  moves             Move[]
  fiscalPositions   FiscalPosition[]
  payments          Payment[]
  partialReconciles PartialReconcile[]
  bankStatements    BankStatement[]
  batchPayments     BatchPayment[]
  fiscalYears       FiscalYear[]
  recurringEntries  RecurringEntry[]
  budgets           Budget[]

  // Contracting relations
  destinations     Destination[]
  cities           City[]
  zones            Zone[]
  hotelAmenities   HotelAmenity[]
  hotels           Hotel[]
  contracts        Contract[]
  markets          Market[]
  tourOperators    TourOperator[]
  markupRules      MarkupRule[]
  tariffs          Tariff[]
  rateVerifications RateVerification[]
  copyLogs         ContractCopyLog[]
  apiKeys          ApiKey[]
  apiIntegrations  ApiIntegration[]

  // Reservations relations
  guests           Guest[]
  bookings         Booking[]
  vouchers         Voucher[]
  notifications    Notification[]

  // Traffic relations
  ttZones              TtZone[]
  ttVehicleTypes       TtVehicleType[]
  ttVehicles           TtVehicle[]
  ttVehicleCompliances TtVehicleCompliance[]
  ttDrivers            TtDriver[]
  ttDriverVehicles     TtDriverVehicle[]
  ttReps               TtRep[]
  ttRepZones           TtRepZone[]
  ttPriceItems         TtPriceItem[]
  ttPartnerPriceOverrides TtPartnerPriceOverride[]
  ttSupplierTripPrices TtSupplierTripPrice[]
  ttTrafficJobs        TtTrafficJob[]
  ttTrafficFlights     TtTrafficFlight[]
  ttTrafficAssignments TtTrafficAssignment[]
  ttGuestBookings      TtGuestBooking[]
  ttOperationalCosts   TtOperationalCost[]
  ttSettings           TtSettings?

  @@index([countryId])
  @@index([baseCurrencyId])
}

model CompanySetup {
  id              String   @id @default(cuid())
  companyId       String   @unique
  isComplete      Boolean  @default(false)
  currentStep     Int      @default(1)
  completedSteps  Json     @default("[]") // array of completed step numbers
  moduleConfig    Json?    // module-specific config from setup wizard
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============================================================================
// USERS & RBAC
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash for credentials auth
  isActive      Boolean   @default(true)
  companyId     String?
  locale        String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company   Company?    @relation(fields: [companyId], references: [id])
  accounts  AuthAccount[]
  sessions  Session[]
  userRoles UserRole[]
  closedFiscalYears   FiscalYear[]   @relation("FiscalYearClosedBy")
  lockedFiscalPeriods FiscalPeriod[] @relation("FiscalPeriodLockedBy")

  // Contracting relations
  contractsCreated   Contract[] @relation("ContractCreator")
  contractsPosted    Contract[] @relation("ContractPoster")
  contractsPublished Contract[] @relation("ContractPublisher")
  contractCopyLogs       ContractCopyLog[]
  rateVerifications      RateVerification[]  @relation("RateVerificationCreator")

  // Reservations relations
  bookingsCreated    Booking[]          @relation("BookingCreator")
  bookingsConfirmed  Booking[]          @relation("BookingConfirmer")
  bookingsCancelled  Booking[]          @relation("BookingCanceller")
  bookingsCheckedIn  Booking[]          @relation("BookingCheckIn")
  bookingsCheckedOut Booking[]          @relation("BookingCheckOut")
  bookingsLocked     Booking[]          @relation("BookingLocker")
  bookingsApproved   Booking[]          @relation("BookingApprover")
  notifications      Notification[]     @relation("NotificationRecipient")
  bookingPayments    BookingPayment[]   @relation("BookingPaymentCreator")
  vouchersCreated    Voucher[]          @relation("VoucherCreator")
  bookingTimelines   BookingTimeline[]  @relation("TimelineUser")

  // Traffic relations
  ttDriver           TtDriver?
  ttRep              TtRep?
  ttPushTokens       TtPushToken[]
  ttJobsCreated      TtTrafficJob[]     @relation("TtJobCreator")

  @@index([companyId])
  @@index([email])
}

model Role {
  id          String   @id @default(cuid())
  name        String   // e.g. "super_admin", "finance_manager"
  displayName String
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be deleted
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([name, companyId])
  @@index([companyId])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "finance:invoice:create"
  module      String   // e.g. "finance"
  resource    String   // e.g. "invoice"
  action      String   // e.g. "create"
  displayName String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@index([module, resource])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================================================
// REFERENCE DATA
// ============================================================================

model Country {
  id        String  @id @default(cuid())
  code      String  @unique // ISO 3166-1 alpha-2
  code3     String? @unique // ISO 3166-1 alpha-3
  name      String
  nameAr    String? // Arabic name
  phone     String? // phone code e.g. "+20"
  continent String?
  isActive  Boolean @default(true)

  states          CountryState[]
  companies       Company[]
  partners        Partner[]
  fiscalPositions FiscalPosition[]

  // Contracting relations
  destinations  Destination[]
  hotels        Hotel[]
  tourOperators TourOperator[] @relation("TOCountry")
  guests        Guest[]        @relation("GuestCountry")

  // Traffic relations
  airports Airport[]

  @@index([code])
  @@index([name])
}

model CountryState {
  id        String  @id @default(cuid())
  code      String
  name      String
  nameAr    String?
  countryId String
  isActive  Boolean @default(true)

  country  Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  partners Partner[]

  // Contracting relations
  hotels Hotel[]

  @@unique([code, countryId])
  @@index([countryId])
}

model Currency {
  id        String  @id @default(cuid())
  code      String  @unique // ISO 4217
  name      String
  nameAr    String?
  symbol    String
  decimals  Int     @default(2)
  isActive  Boolean @default(true)

  companies     Company[]
  rates         CurrencyRate[]

  // Finance relations
  finAccounts   FinAccount[]
  journals      Journal[]

  // Move relations
  movesAsCurrency        Move[] @relation("MoveCurrency")
  movesAsCompanyCurrency Move[] @relation("MoveCompanyCurrency")
  moveLineItems          MoveLineItem[]
  payments               Payment[]

  // Contracting relations
  contracts              Contract[] @relation("ContractBaseCurrency")

  // Reservations relations
  bookings               Booking[]        @relation("BookingCurrency")
  bookingPayments        BookingPayment[] @relation("BookingPaymentCurrency")

  // Traffic relations
  ttPriceItems           TtPriceItem[]
  ttSupplierTripPrices   TtSupplierTripPrice[]
  ttTrafficJobs          TtTrafficJob[]         @relation("TtJobCurrency")
  ttGuestBookings        TtGuestBooking[]       @relation("TtGuestBookingCurrency")
  ttOperationalCosts     TtOperationalCost[]    @relation("TtOpCostCurrency")

  @@index([code])
}

model CurrencyRate {
  id         String   @id @default(cuid())
  currencyId String
  companyId  String
  rate       Decimal  @db.Decimal(18, 6) // rate to base currency
  date       DateTime @db.Date
  source     String   @default("manual") // "manual", "api", "import"
  createdAt  DateTime @default(now())

  currency Currency @relation(fields: [currencyId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([currencyId, companyId, date])
  @@index([companyId, date])
  @@index([currencyId])
}

model Language {
  id       String  @id @default(cuid())
  code     String  @unique // e.g. "en", "ar", "fr"
  name     String           // e.g. "English"
  nameAr   String?          // e.g. "الإنجليزية"
  isRTL    Boolean @default(false)
  isActive Boolean @default(true)

  @@index([code])
}

model PartnerTitle {
  id       String  @id @default(cuid())
  name     String  @unique // e.g. "Mr.", "Mrs.", "Dr."
  nameAr   String?
  isActive Boolean @default(true)

  partners Partner[]
}

// ============================================================================
// PARTNER (Unified: Customer, Supplier, Tour Operator, Corporate)
// ============================================================================

model Partner {
  id            String   @id @default(cuid())
  companyId     String
  type          String   @default("customer") // customer, supplier, tour_operator, corporate, individual
  isCompany     Boolean  @default(false) // true = organization, false = individual
  name          String
  displayName   String?
  titleId       String?
  email         String?
  phone         String?
  mobile        String?
  website       String?
  taxId         String?
  notes         String?  @db.Text
  countryId     String?
  stateId       String?
  city          String?
  street        String?
  zip           String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title    PartnerTitle?  @relation(fields: [titleId], references: [id])
  country  Country?       @relation(fields: [countryId], references: [id])
  state    CountryState?  @relation(fields: [stateId], references: [id])

  moves              Move[]
  moveLineItems      MoveLineItem[]
  payments           Payment[]
  bankStatementLines BankStatementLine[]
  recurringEntries   RecurringEntry[]
  guests             Guest[]

  // Traffic relations
  ttVehicles             TtVehicle[]
  ttPriceOverrides       TtPartnerPriceOverride[]
  ttTrafficJobs          TtTrafficJob[]
  ttSupplierTripPrices   TtSupplierTripPrice[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([name])
  @@index([email])
  @@index([countryId])
}

// ============================================================================
// SEQUENCE GENERATOR
// ============================================================================

model Sequence {
  id          String   @id @default(cuid())
  companyId   String
  code        String   // e.g. "invoice", "booking", "contract"
  prefix      String   // e.g. "INV", "BK", "CTR"
  separator   String   @default("-") // e.g. "-", "/"
  padding     Int      @default(5)   // number padding e.g. 00001
  nextNumber  Int      @default(1)
  formatType  String   @default("standard") // "standard" or "company_serial"
  startNumber Int      @default(1)
  resetPolicy String   @default("yearly") // "yearly", "monthly", "never"
  lastReset   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId])
}

// ============================================================================
// MODULE REGISTRY
// ============================================================================

model InstalledModule {
  id          String    @id @default(cuid())
  companyId   String
  name        String    // "finance", "contracting", "crm", "reservations", "traffic"
  displayName String    // "Finance & Accounting"
  version     String    @default("1.0.0")
  isInstalled Boolean   @default(false)
  installedAt DateTime?
  config      Json?     // module-specific config from setup wizard
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([name, companyId])
  @@index([companyId])
  @@index([companyId, isInstalled])
}

// ============================================================================
// FINANCE MODULE — Enums
// ============================================================================

enum AccountType {
  ASSET_RECEIVABLE
  ASSET_CASH
  ASSET_CURRENT
  ASSET_NON_CURRENT
  ASSET_PREPAYMENTS
  ASSET_FIXED
  LIABILITY_PAYABLE
  LIABILITY_CREDIT_CARD
  LIABILITY_CURRENT
  LIABILITY_NON_CURRENT
  EQUITY
  EQUITY_UNAFFECTED
  INCOME
  INCOME_OTHER
  EXPENSE
  EXPENSE_DEPRECIATION
  EXPENSE_DIRECT_COST
  OFF_BALANCE
}

enum JournalType {
  SALE
  PURCHASE
  CASH
  BANK
  CREDIT_CARD
  GENERAL
}

enum TaxUse {
  SALE
  PURCHASE
  NONE
}

enum TaxAmountType {
  PERCENT
  FIXED
  GROUP
  DIVISION
}

enum TaxScope {
  SERVICE
  PRODUCT
}

enum TaxDocType {
  INVOICE
  REFUND
}

enum TermValueType {
  BALANCE
  PERCENT
  FIXED
}

enum DelayType {
  DAYS_AFTER
  DAYS_AFTER_END_OF_MONTH
  DAYS_AFTER_END_OF_NEXT_MONTH
}

enum MoveType {
  ENTRY
  OUT_INVOICE
  OUT_REFUND
  IN_INVOICE
  IN_REFUND
}

enum MoveState {
  DRAFT
  POSTED
  CANCELLED
}

enum PaymentState {
  NOT_PAID
  IN_PAYMENT
  PAID
  PARTIAL
  REVERSED
}

enum DisplayType {
  PRODUCT
  TAX
  ROUNDING
  PAYMENT_TERM
  LINE_SECTION
  LINE_NOTE
}

enum PaymentType {
  INBOUND
  OUTBOUND
}

enum BankStatementState {
  DRAFT
  VALIDATED
}

enum FiscalYearState {
  OPEN
  CLOSED
}

enum FiscalPeriodState {
  OPEN
  LOCKED
  CLOSED
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringState {
  ACTIVE
  PAUSED
  DONE
}

enum BudgetState {
  DRAFT
  APPROVED
  CANCELLED
}

// ============================================================================
// CONTRACTING MODULE — Enums
// ============================================================================

enum StarRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
  FIVE_DELUXE
}

enum MealCode {
  RO
  BB
  HB
  FB
  AI
  UAI
  PRAI
  SC
}

enum ChildAgeCategory {
  INFANT
  CHILD
  TEEN
}

enum ChildBedding {
  SHARING_WITH_PARENTS
  EXTRA_BED
  OWN_BED
}

enum ContractStatus {
  DRAFT
  POSTED
  PUBLISHED
}

enum RateBasis {
  PER_PERSON
  PER_ROOM
}

enum SupplementType {
  ROOM_TYPE
  MEAL
  OCCUPANCY
  EXTRA_BED
}

enum CopyRateMode {
  FREEZE
  INCREASE
  DECREASE
  AVERAGE
}

enum SupplementValueType {
  FIXED
  PERCENTAGE
}

enum OfferType {
  EARLY_BIRD
  NORMAL_EBD
  LONG_STAY
  FREE_NIGHTS
  HONEYMOON
  GROUP_DISCOUNT

  @@map("offer_type")
}

// ============================================================================
// FINANCE MODULE — Chart of Accounts
// ============================================================================

model AccountGroup {
  id              String  @id @default(cuid())
  companyId       String
  name            String
  codePrefixStart String
  codePrefixEnd   String
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   AccountGroup? @relation("AccountGroupHierarchy", fields: [parentId], references: [id])
  children AccountGroup[] @relation("AccountGroupHierarchy")
  accounts FinAccount[]

  @@unique([name, companyId])
  @@index([companyId])
}

model AccountTag {
  id    String @id @default(cuid())
  name  String @unique
  color Int    @default(0)

  accounts FinAccount[]
}

model FinAccount {
  id          String      @id @default(cuid())
  companyId   String
  code        String
  name        String
  accountType AccountType
  reconcile   Boolean     @default(false)
  deprecated  Boolean     @default(false)
  groupId     String?
  currencyId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  group       AccountGroup? @relation(fields: [groupId], references: [id])
  currency    Currency?     @relation(fields: [currencyId], references: [id])
  tags        AccountTag[]
  defaultTaxes Tax[]        @relation("AccountDefaultTaxes")

  // Reverse relations for journal defaults
  journalDefaults       Journal[] @relation("JournalDefaultAccount")
  journalSuspense       Journal[] @relation("JournalSuspenseAccount")
  journalProfit         Journal[] @relation("JournalProfitAccount")
  journalLoss           Journal[] @relation("JournalLossAccount")
  taxRepartitionLines   TaxRepartitionLine[]
  moveLineItems         MoveLineItem[]

  // Fiscal position relations
  fpAccountSrcMaps  FiscalPositionAccountMap[] @relation("FPAccountSrc")
  fpAccountDestMaps FiscalPositionAccountMap[] @relation("FPAccountDest")
  recurringEntryLines RecurringEntryLine[]
  budgetLines         BudgetLine[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([companyId, accountType])
  @@index([code])
  @@map("fin_account")
}

// ============================================================================
// FINANCE MODULE — Journals
// ============================================================================

model Journal {
  id                  String      @id @default(cuid())
  companyId           String
  name                String
  code                String
  type                JournalType
  defaultAccountId    String?
  suspenseAccountId   String?
  profitAccountId     String?
  lossAccountId       String?
  currencyId          String?
  sequencePrefix      String?
  sequenceNextNumber  Int         @default(1)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultAccount   FinAccount? @relation("JournalDefaultAccount", fields: [defaultAccountId], references: [id])
  suspenseAccount  FinAccount? @relation("JournalSuspenseAccount", fields: [suspenseAccountId], references: [id])
  profitAccount    FinAccount? @relation("JournalProfitAccount", fields: [profitAccountId], references: [id])
  lossAccount      FinAccount? @relation("JournalLossAccount", fields: [lossAccountId], references: [id])
  currency         Currency?   @relation(fields: [currencyId], references: [id])
  moves            Move[]
  payments         Payment[]
  bankStatements   BankStatement[]
  batchPayments    BatchPayment[]
  recurringEntries RecurringEntry[]

  @@unique([code, companyId])
  @@index([companyId])
  @@index([companyId, type])
}

// ============================================================================
// FINANCE MODULE — Taxes
// ============================================================================

model TaxGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sequence  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taxes   Tax[]

  @@unique([name, companyId])
  @@index([companyId])
}

model Tax {
  id               String        @id @default(cuid())
  companyId        String
  name             String
  typeTaxUse       TaxUse        @default(SALE)
  amountType       TaxAmountType @default(PERCENT)
  amount           Decimal       @db.Decimal(12, 4) // the rate or fixed amount
  priceInclude     Boolean       @default(false)
  includeBaseAmount Boolean      @default(false)
  taxGroupId       String?
  taxScope         TaxScope?
  isActive         Boolean       @default(true)
  sequence         Int           @default(10)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taxGroup         TaxGroup?            @relation(fields: [taxGroupId], references: [id])
  repartitionLines TaxRepartitionLine[]
  defaultForAccounts FinAccount[]       @relation("AccountDefaultTaxes")

  // Move relations
  taxSourceLines      MoveLineItem[] @relation("TaxLineSource")
  moveLineItemTaxes   MoveLineItem[] @relation("MoveLineItemTaxes")

  // Fiscal position relations
  fpTaxSrcMaps  FiscalPositionTaxMap[] @relation("FPTaxSrc")
  fpTaxDestMaps FiscalPositionTaxMap[] @relation("FPTaxDest")

  @@index([companyId])
  @@index([companyId, typeTaxUse])
}

model TaxRepartitionLine {
  id             String     @id @default(cuid())
  taxId          String
  factorPercent  Decimal    @db.Decimal(8, 4) @default(100)
  accountId      String?
  useInTaxClosing Boolean   @default(true)
  documentType   TaxDocType @default(INVOICE)
  sequence       Int        @default(10)

  tax     Tax        @relation(fields: [taxId], references: [id], onDelete: Cascade)
  account FinAccount? @relation(fields: [accountId], references: [id])

  @@index([taxId])
}

// ============================================================================
// FINANCE MODULE — Payment Terms
// ============================================================================

model PaymentTerm {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  note            String?
  earlyDiscount   Boolean  @default(false)
  discountPercent Decimal? @db.Decimal(5, 2)
  discountDays    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   PaymentTermLine[]
  moves   Move[]

  @@unique([name, companyId])
  @@index([companyId])
}

model PaymentTermLine {
  id            String        @id @default(cuid())
  paymentTermId String
  valueType     TermValueType @default(BALANCE)
  valueAmount   Decimal       @db.Decimal(12, 4) @default(0)
  nbDays        Int           @default(0)
  delayType     DelayType     @default(DAYS_AFTER)
  sequence      Int           @default(10)

  paymentTerm PaymentTerm @relation(fields: [paymentTermId], references: [id], onDelete: Cascade)

  @@index([paymentTermId])
}

// ============================================================================
// FINANCE MODULE — Moves (Journal Entries / Invoices / Bills)
// ============================================================================

model Move {
  id                String        @id @default(cuid())
  companyId         String
  name              String?       // sequence number e.g. INV/2026/00001
  moveType          MoveType      @default(ENTRY)
  state             MoveState     @default(DRAFT)
  paymentState      PaymentState  @default(NOT_PAID)
  date              DateTime      @db.Date
  journalId         String
  partnerId         String?
  currencyId        String
  companyCurrencyId String
  invoiceDate       DateTime?     @db.Date
  invoiceDateDue    DateTime?     @db.Date
  paymentTermId     String?
  amountUntaxed     Decimal       @default(0) @db.Decimal(12, 4)
  amountTax         Decimal       @default(0) @db.Decimal(12, 4)
  amountTotal       Decimal       @default(0) @db.Decimal(12, 4)
  amountResidual    Decimal       @default(0) @db.Decimal(12, 4)
  ref               String?
  narration         String?       @db.Text
  reversedEntryId   String?
  fiscalPositionId  String?
  postedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journal         Journal         @relation(fields: [journalId], references: [id])
  partner         Partner?        @relation(fields: [partnerId], references: [id])
  currency        Currency        @relation("MoveCurrency", fields: [currencyId], references: [id])
  companyCurrency Currency        @relation("MoveCompanyCurrency", fields: [companyCurrencyId], references: [id])
  paymentTerm     PaymentTerm?    @relation(fields: [paymentTermId], references: [id])
  reversedEntry   Move?           @relation("MoveReversal", fields: [reversedEntryId], references: [id])
  reversals       Move[]          @relation("MoveReversal")
  fiscalPosition  FiscalPosition? @relation(fields: [fiscalPositionId], references: [id])
  lineItems       MoveLineItem[]
  paymentInvoices Payment[]       @relation("PaymentInvoices")
  paymentMove     Payment?        @relation("PaymentMove")
  exchangeReconciles PartialReconcile[] @relation("ExchangeMove")
  closingForYear     FiscalYear?        @relation("YearClosingMove")

  @@index([companyId])
  @@index([companyId, moveType])
  @@index([companyId, state])
  @@index([partnerId])
  @@index([journalId])
  @@index([date])
  @@map("fin_move")
}

model MoveLineItem {
  id             String      @id @default(cuid())
  moveId         String
  accountId      String
  partnerId      String?
  name           String?
  displayType    DisplayType @default(PRODUCT)
  debit          Decimal     @default(0) @db.Decimal(12, 4)
  credit         Decimal     @default(0) @db.Decimal(12, 4)
  balance        Decimal     @default(0) @db.Decimal(12, 4)
  amountCurrency Decimal     @default(0) @db.Decimal(12, 4)
  currencyId     String?
  quantity       Decimal     @default(1) @db.Decimal(12, 4)
  priceUnit      Decimal     @default(0) @db.Decimal(12, 4)
  discount       Decimal     @default(0) @db.Decimal(5, 2)
  taxLineId      String?
  dateMaturity   DateTime?   @db.Date
  sequence       Int         @default(10)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  move      Move        @relation(fields: [moveId], references: [id], onDelete: Cascade)
  account   FinAccount  @relation(fields: [accountId], references: [id])
  partner   Partner?    @relation(fields: [partnerId], references: [id])
  currency  Currency?   @relation(fields: [currencyId], references: [id])
  taxLine   Tax?        @relation("TaxLineSource", fields: [taxLineId], references: [id])
  taxes     Tax[]       @relation("MoveLineItemTaxes")

  debitReconciles    PartialReconcile[]  @relation("DebitReconcileLine")
  creditReconciles   PartialReconcile[]  @relation("CreditReconcileLine")
  bankStatementLine  BankStatementLine?

  @@index([moveId])
  @@index([accountId])
  @@index([displayType])
  @@map("fin_move_line_item")
}

// ============================================================================
// FINANCE MODULE — Fiscal Positions
// ============================================================================

model FiscalPosition {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  autoApply   Boolean  @default(false)
  countryId   String?
  vatRequired Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country     Country?                 @relation(fields: [countryId], references: [id])
  taxMaps     FiscalPositionTaxMap[]
  accountMaps FiscalPositionAccountMap[]
  moves       Move[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("fin_fiscal_position")
}

model FiscalPositionTaxMap {
  id               String @id @default(cuid())
  fiscalPositionId String
  taxSrcId         String
  taxDestId        String

  fiscalPosition FiscalPosition @relation(fields: [fiscalPositionId], references: [id], onDelete: Cascade)
  taxSrc         Tax            @relation("FPTaxSrc", fields: [taxSrcId], references: [id])
  taxDest        Tax            @relation("FPTaxDest", fields: [taxDestId], references: [id])

  @@index([fiscalPositionId])
  @@map("fin_fiscal_position_tax_map")
}

model FiscalPositionAccountMap {
  id               String @id @default(cuid())
  fiscalPositionId String
  accountSrcId     String
  accountDestId    String

  fiscalPosition FiscalPosition @relation(fields: [fiscalPositionId], references: [id], onDelete: Cascade)
  accountSrc     FinAccount     @relation("FPAccountSrc", fields: [accountSrcId], references: [id])
  accountDest    FinAccount     @relation("FPAccountDest", fields: [accountDestId], references: [id])

  @@index([fiscalPositionId])
  @@map("fin_fiscal_position_account_map")
}

// ============================================================================
// FINANCE MODULE — Payments
// ============================================================================

model Payment {
  id          String      @id @default(cuid())
  companyId   String
  name        String?
  paymentType PaymentType
  partnerId   String?
  amount      Decimal     @db.Decimal(12, 4)
  currencyId  String
  date        DateTime    @db.Date
  journalId   String
  moveId      String?     @unique
  ref         String?
  state       MoveState   @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  batchPaymentId String?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner      Partner?      @relation(fields: [partnerId], references: [id])
  currency     Currency      @relation(fields: [currencyId], references: [id])
  journal      Journal       @relation(fields: [journalId], references: [id])
  move         Move?         @relation("PaymentMove", fields: [moveId], references: [id])
  invoices     Move[]        @relation("PaymentInvoices")
  batchPayment BatchPayment? @relation("BatchPaymentPayments", fields: [batchPaymentId], references: [id])

  @@index([companyId])
  @@index([companyId, state])
  @@index([partnerId])
  @@index([batchPaymentId])
  @@map("fin_payment")
}

// ============================================================================
// FINANCE MODULE — Reconciliation
// ============================================================================

model PartialReconcile {
  id               String   @id @default(cuid())
  companyId        String
  debitMoveLineId  String
  creditMoveLineId String
  amount           Decimal  @db.Decimal(12, 4)
  exchangeMoveId   String?
  createdAt        DateTime @default(now())

  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  debitMoveLine   MoveLineItem @relation("DebitReconcileLine", fields: [debitMoveLineId], references: [id])
  creditMoveLine  MoveLineItem @relation("CreditReconcileLine", fields: [creditMoveLineId], references: [id])
  exchangeMove    Move?        @relation("ExchangeMove", fields: [exchangeMoveId], references: [id])

  @@index([companyId])
  @@index([debitMoveLineId])
  @@index([creditMoveLineId])
  @@map("fin_partial_reconcile")
}

// ============================================================================
// FINANCE MODULE — Bank Statements
// ============================================================================

model BankStatement {
  id             String             @id @default(cuid())
  companyId      String
  name           String?
  journalId      String
  date           DateTime           @db.Date
  dateFrom       DateTime?          @db.Date
  dateTo         DateTime?          @db.Date
  balanceStart   Decimal            @default(0) @db.Decimal(12, 4)
  balanceEnd     Decimal            @default(0) @db.Decimal(12, 4)
  balanceEndReal Decimal            @default(0) @db.Decimal(12, 4)
  state          BankStatementState @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journal Journal             @relation(fields: [journalId], references: [id])
  lines   BankStatementLine[]

  @@index([companyId])
  @@index([companyId, journalId])
  @@index([date])
  @@map("fin_bank_statement")
}

model BankStatementLine {
  id           String   @id @default(cuid())
  statementId  String
  sequence     Int      @default(10)
  date         DateTime @db.Date
  name         String
  ref          String?
  partnerId    String?
  amount       Decimal  @db.Decimal(12, 4)
  moveLineId   String?  @unique
  isReconciled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  partner   Partner?      @relation(fields: [partnerId], references: [id])
  moveLine  MoveLineItem? @relation(fields: [moveLineId], references: [id])

  @@index([statementId])
  @@index([isReconciled])
  @@map("fin_bank_statement_line")
}

// ============================================================================
// FINANCE MODULE — Batch Payments
// ============================================================================

model BatchPayment {
  id           String      @id @default(cuid())
  companyId    String
  name         String?
  journalId    String
  date         DateTime    @db.Date
  paymentType  PaymentType
  state        MoveState   @default(DRAFT)
  totalAmount  Decimal     @default(0) @db.Decimal(12, 4)
  paymentCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journal  Journal   @relation(fields: [journalId], references: [id])
  payments Payment[] @relation("BatchPaymentPayments")

  @@index([companyId])
  @@index([companyId, state])
  @@map("fin_batch_payment")
}

// ── FINANCE MODULE — Fiscal Year & Period Management ──

model FiscalYear {
  id            String          @id @default(cuid())
  companyId     String
  name          String
  code          String
  dateFrom      DateTime        @db.Date
  dateTo        DateTime        @db.Date
  state         FiscalYearState @default(OPEN)
  closingMoveId String?         @unique
  closedBy      String?
  closedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  closingMove  Move?          @relation("YearClosingMove", fields: [closingMoveId], references: [id])
  closedByUser User?          @relation("FiscalYearClosedBy", fields: [closedBy], references: [id])
  periods      FiscalPeriod[]
  budgets      Budget[]

  @@unique([companyId, code])
  @@unique([companyId, dateFrom])
  @@index([companyId])
  @@index([companyId, state])
  @@map("fin_fiscal_year")
}

model FiscalPeriod {
  id           String            @id @default(cuid())
  fiscalYearId String
  name         String
  code         String
  number       Int
  dateFrom     DateTime          @db.Date
  dateTo       DateTime          @db.Date
  state        FiscalPeriodState @default(OPEN)
  lockedBy     String?
  lockedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  lockedByUser User?      @relation("FiscalPeriodLockedBy", fields: [lockedBy], references: [id])

  @@unique([fiscalYearId, number])
  @@unique([fiscalYearId, code])
  @@index([fiscalYearId])
  @@index([fiscalYearId, state])
  @@map("fin_fiscal_period")
}

// ── FINANCE MODULE — Recurring Entries ──

model RecurringEntry {
  id             String             @id @default(cuid())
  companyId      String
  name           String
  journalId      String
  partnerId      String?
  currencyId     String
  ref            String?
  frequency      RecurringFrequency @default(MONTHLY)
  state          RecurringState     @default(ACTIVE)
  nextRunDate    DateTime           @db.Date
  endDate        DateTime?          @db.Date
  lastRunDate    DateTime?          @db.Date
  totalGenerated Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journal       Journal              @relation(fields: [journalId], references: [id])
  partner       Partner?             @relation(fields: [partnerId], references: [id])
  lineTemplates RecurringEntryLine[]

  @@index([companyId])
  @@index([companyId, state])
  @@index([nextRunDate])
  @@map("fin_recurring_entry")
}

model RecurringEntryLine {
  id               String  @id @default(cuid())
  recurringEntryId String
  accountId        String
  partnerId        String?
  name             String?
  debit            Decimal @default(0) @db.Decimal(12, 4)
  credit           Decimal @default(0) @db.Decimal(12, 4)
  sequence         Int     @default(10)

  recurringEntry RecurringEntry @relation(fields: [recurringEntryId], references: [id], onDelete: Cascade)
  account        FinAccount     @relation(fields: [accountId], references: [id])

  @@index([recurringEntryId])
  @@map("fin_recurring_entry_line")
}

// ── FINANCE MODULE — Budgets ──

model Budget {
  id           String      @id @default(cuid())
  companyId    String
  name         String
  fiscalYearId String
  state        BudgetState @default(DRAFT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear  @relation(fields: [fiscalYearId], references: [id])
  lines      BudgetLine[]

  @@unique([name, companyId])
  @@index([companyId])
  @@index([companyId, fiscalYearId])
  @@map("fin_budget")
}

model BudgetLine {
  id           String  @id @default(cuid())
  budgetId     String
  accountId    String
  amount01     Decimal @default(0) @db.Decimal(12, 4)
  amount02     Decimal @default(0) @db.Decimal(12, 4)
  amount03     Decimal @default(0) @db.Decimal(12, 4)
  amount04     Decimal @default(0) @db.Decimal(12, 4)
  amount05     Decimal @default(0) @db.Decimal(12, 4)
  amount06     Decimal @default(0) @db.Decimal(12, 4)
  amount07     Decimal @default(0) @db.Decimal(12, 4)
  amount08     Decimal @default(0) @db.Decimal(12, 4)
  amount09     Decimal @default(0) @db.Decimal(12, 4)
  amount10     Decimal @default(0) @db.Decimal(12, 4)
  amount11     Decimal @default(0) @db.Decimal(12, 4)
  amount12     Decimal @default(0) @db.Decimal(12, 4)
  annualAmount Decimal @default(0) @db.Decimal(12, 4)

  budget  Budget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account FinAccount @relation(fields: [accountId], references: [id])

  @@unique([budgetId, accountId])
  @@index([budgetId])
  @@map("fin_budget_line")
}

// ============================================================================
// CONTRACTING MODULE — Hotel Master Data
// ============================================================================

model Destination {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  countryId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country     Country      @relation(fields: [countryId], references: [id])
  hotels      Hotel[]
  cities      City[]
  markupRules MarkupRule[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([countryId])
  @@map("ct_destination")
}

model City {
  id            String   @id @default(cuid())
  companyId     String
  destinationId String
  name          String
  code          String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  hotels      Hotel[]
  zones       Zone[]

  // Traffic relations
  ttZones TtZone[]

  @@unique([companyId, destinationId, code])
  @@index([companyId])
  @@index([destinationId])
  @@map("ct_city")
}

model Zone {
  id        String   @id @default(cuid())
  companyId String
  cityId    String
  name      String
  code      String   // 1 letter, e.g. "A", "B"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  city    City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  hotels  Hotel[]

  @@unique([companyId, cityId, code])
  @@index([companyId])
  @@index([cityId])
  @@map("ct_zone")
}

model HotelAmenity {
  id        String   @id @default(cuid())
  companyId String
  name      String
  icon      String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hotels  Hotel[]

  @@index([companyId])
  @@map("ct_hotel_amenity")
}

model Hotel {
  id               String     @id @default(cuid())
  companyId        String
  name             String
  code             String
  starRating       StarRating @default(THREE)
  chainName        String?
  description      String?    @db.Text
  shortDescription String?
  address          String?
  city             String
  stateId          String?
  countryId        String
  zipCode          String?
  latitude         Float?
  longitude        Float?
  destinationId    String?
  cityId           String?
  zoneId           String?
  phone            String?
  fax              String?
  email            String?
  website          String?
  reservationEmail String?
  contactPerson    String?
  contactPhone     String?
  checkInTime      String     @default("14:00")
  checkOutTime     String     @default("12:00")
  totalRooms       Int?
  yearBuilt        Int?
  yearRenovated    Int?
  giataId          String?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  state       CountryState? @relation(fields: [stateId], references: [id])
  country     Country       @relation(fields: [countryId], references: [id])
  destination Destination?  @relation(fields: [destinationId], references: [id])
  cityRel     City?         @relation(fields: [cityId], references: [id])
  zone        Zone?         @relation(fields: [zoneId], references: [id])

  amenities        HotelAmenity[]
  roomTypes        HotelRoomType[]
  childrenPolicies ChildPolicy[]
  mealBasis        HotelMealBasis[]
  images           HotelImage[]
  contracts        Contract[]

  tourOperators         HotelTourOperator[]
  markupRules           MarkupRule[]       @relation("MarkupRuleHotel")
  apiIntegrationHotels  ApiIntegrationHotel[]
  bookings              Booking[]

  // Traffic relations
  ttJobsPickup   TtTrafficJob[] @relation("TtJobPickupHotel")
  ttJobsDropoff  TtTrafficJob[] @relation("TtJobDropoffHotel")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([countryId])
  @@index([destinationId])
  @@index([cityId])
  @@index([zoneId])
  @@map("ct_hotel")
}

model HotelImage {
  id        String  @id @default(cuid())
  hotelId   String
  url       String
  caption   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("ct_hotel_image")
}

model HotelRoomType {
  id                String  @id @default(cuid())
  hotelId           String
  name              String
  code              String
  description       String? @db.Text
  sortOrder         Int     @default(0)
  minAdults         Int     @default(1)
  standardAdults    Int     @default(2)
  maxAdults         Int     @default(2)
  maxChildren       Int     @default(1)
  maxInfants        Int     @default(1)
  maxOccupancy      Int     @default(3)
  extraBedAvailable Boolean @default(false)
  maxExtraBeds      Int     @default(0)
  roomSize          Float?
  bedConfiguration  String?
  active            Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  occupancyTable     RoomTypeOccupancy[]
  contractRoomTypes   ContractRoomType[]
  baseForContracts    Contract[]          @relation("ContractBaseRoom")
  contractSupplements ContractSupplement[]
  contractAllotments  ContractAllotment[]
  contractStopSales   ContractStopSale[]
  bookingRooms        BookingRoom[]       @relation("BookingRoomType")

  @@unique([hotelId, code])
  @@index([hotelId])
  @@map("ct_hotel_room_type")
}

model RoomTypeOccupancy {
  id          String  @id @default(cuid())
  roomTypeId  String
  adults      Int
  children    Int     @default(0)
  infants     Int     @default(0)
  extraBeds   Int     @default(0)
  isDefault   Boolean @default(false)
  description String?
  sortOrder   Int     @default(0)

  roomType HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, adults, children, infants, extraBeds])
  @@index([roomTypeId])
  @@map("ct_room_type_occupancy")
}

model ChildPolicy {
  id              String           @id @default(cuid())
  hotelId         String
  category        ChildAgeCategory
  ageFrom         Int
  ageTo           Int
  label           String
  freeInSharing   Boolean          @default(false)
  maxFreePerRoom  Int              @default(0)
  extraBedAllowed Boolean          @default(true)
  mealsIncluded    Boolean          @default(false)
  chargePercentage Int              @default(100)
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, category])
  @@index([hotelId])
  @@map("ct_child_policy")
}

model HotelMealBasis {
  id          String   @id @default(cuid())
  hotelId     String
  mealCode    MealCode
  name        String
  description String?
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel             Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  contractMealBasis   ContractMealBasis[]
  baseForContracts    Contract[]         @relation("ContractBaseMeal")
  contractSupplements ContractSupplement[]
  bookingRooms        BookingRoom[]       @relation("BookingMealBasis")

  @@unique([hotelId, mealCode])
  @@index([hotelId])
  @@map("ct_hotel_meal_basis")
}

// ─── Contract Core ───────────────────────────────────────

model Contract {
  id              String         @id @default(cuid())
  companyId       String
  name            String
  code            String
  season          String?
  status          ContractStatus @default(DRAFT)
  hotelId         String
  validFrom       DateTime       @db.Date
  validTo         DateTime       @db.Date
  travelFrom      DateTime?      @db.Date
  travelTo        DateTime?      @db.Date
  rateBasis       RateBasis
  baseCurrencyId  String
  baseRoomTypeId  String
  baseMealBasisId String
  minimumStay     Int            @default(1)
  maximumStay     Int?
  terms           String?        @db.Text
  internalNotes   String?        @db.Text
  hotelNotes      String?        @db.Text
  createdById     String
  postedById      String?
  postedAt        DateTime?
  publishedById   String?
  publishedAt     DateTime?
  parentContractId String?
  version          Int            @default(1)
  isTemplate       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company        Company        @relation(fields: [companyId], references: [id])
  parentContract Contract?      @relation("ContractLineage", fields: [parentContractId], references: [id])
  childContracts Contract[]     @relation("ContractLineage")
  hotel         Hotel          @relation(fields: [hotelId], references: [id])
  baseCurrency  Currency       @relation("ContractBaseCurrency", fields: [baseCurrencyId], references: [id])
  baseRoomType  HotelRoomType  @relation("ContractBaseRoom", fields: [baseRoomTypeId], references: [id])
  baseMealBasis HotelMealBasis @relation("ContractBaseMeal", fields: [baseMealBasisId], references: [id])
  createdBy     User           @relation("ContractCreator", fields: [createdById], references: [id])
  postedBy      User?          @relation("ContractPoster", fields: [postedById], references: [id])
  publishedBy   User?          @relation("ContractPublisher", fields: [publishedById], references: [id])

  seasons       ContractSeason[]
  roomTypes     ContractRoomType[]
  mealBases     ContractMealBasis[]
  baseRates     ContractBaseRate[]
  supplements   ContractSupplement[]
  specialOffers ContractSpecialOffer[]
  seasonSpos    ContractSeasonSpo[]
  allotments    ContractAllotment[]
  stopSales      ContractStopSale[]
  childPolicies         ContractChildPolicy[]
  cancellationPolicies  ContractCancellationPolicy[]
  markets               ContractMarket[]
  auditLogs             ContractAuditLog[]
  tourOperators         ContractTourOperator[]
  markupRules           MarkupRule[]
  tariffs               Tariff[]
  specialMeals          ContractSpecialMeal[]
  marketingContributions ContractMarketingContribution[]
  rateVerifications     RateVerification[]
  copyLogsAsSource      ContractCopyLog[]     @relation("CopyLogSource")
  copyLogsAsTarget      ContractCopyLog[]     @relation("CopyLogTarget")
  bookings              Booking[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isTemplate])
  @@index([hotelId])
  @@index([parentContractId])
  @@map("ct_contract")
}

model ContractSeason {
  id          String   @id @default(cuid())
  contractId  String
  dateFrom    DateTime @db.Date
  dateTo      DateTime @db.Date
  sortOrder   Int      @default(0)
  releaseDays Int      @default(21)
  minimumStay Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contract               Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  baseRates              ContractBaseRate[]
  supplements            ContractSupplement[]
  allotments             ContractAllotment[]
  marketingContributions ContractMarketingContribution[]
  bookings               Booking[]

  @@index([contractId])
  @@map("ct_contract_season")
}

model ContractRoomType {
  id         String  @id @default(cuid())
  contractId String
  roomTypeId String
  isBase     Boolean @default(false)
  sortOrder  Int     @default(0)

  contract Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  roomType HotelRoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([contractId, roomTypeId])
  @@index([contractId])
  @@map("ct_contract_room_type")
}

model ContractMealBasis {
  id          String  @id @default(cuid())
  contractId  String
  mealBasisId String
  isBase      Boolean @default(false)
  sortOrder   Int     @default(0)

  contract  Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  mealBasis HotelMealBasis @relation(fields: [mealBasisId], references: [id])

  @@unique([contractId, mealBasisId])
  @@index([contractId])
  @@map("ct_contract_meal_basis")
}

model ContractBaseRate {
  id         String   @id @default(cuid())
  contractId String
  seasonId   String
  rate       Decimal  @db.Decimal(12, 4)
  singleRate Decimal? @db.Decimal(12, 4)
  doubleRate Decimal? @db.Decimal(12, 4)
  tripleRate Decimal? @db.Decimal(12, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contract Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  season   ContractSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([contractId, seasonId])
  @@index([contractId])
  @@map("ct_contract_base_rate")
}

model ContractSupplement {
  id               String              @id @default(cuid())
  contractId       String
  seasonId         String?
  supplementType   SupplementType
  roomTypeId       String?
  mealBasisId      String?
  forAdults        Int?
  forChildCategory ChildAgeCategory?
  forChildBedding  ChildBedding?
  childPosition    Int?
  valueType        SupplementValueType @default(FIXED)
  value            Decimal             @db.Decimal(12, 4)
  isReduction      Boolean             @default(false)
  perPerson        Boolean             @default(true)
  perNight         Boolean             @default(true)
  label            String?
  notes            String?             @db.Text
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  contract  Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  season    ContractSeason? @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  roomType  HotelRoomType?  @relation(fields: [roomTypeId], references: [id])
  mealBasis HotelMealBasis? @relation(fields: [mealBasisId], references: [id])

  @@index([contractId])
  @@index([contractId, supplementType])
  @@index([seasonId])
  @@map("ct_contract_supplement")
}

model ContractSpecialOffer {
  id              String              @id @default(cuid())
  contractId      String
  name            String
  offerType       OfferType
  description     String?             @db.Text

  // Eligibility
  validFrom       DateTime?           @db.Date
  validTo         DateTime?           @db.Date
  bookByDate      DateTime?           @db.Date
  minimumNights   Int?
  minimumRooms    Int?
  advanceBookDays Int?

  // Discount
  discountType    SupplementValueType @default(FIXED)
  discountValue   Decimal             @db.Decimal(12, 4)

  // Normal EBD fields
  bookFromDate    DateTime?           @db.Date
  stayDateType    String?
  paymentPct      Int?
  paymentDeadline DateTime?           @db.Date
  roomingListBy   DateTime?           @db.Date

  // Free nights (stay X, pay Y)
  stayNights      Int?
  payNights       Int?

  // Flags
  combinable      Boolean             @default(true)
  active          Boolean             @default(true)
  sortOrder       Int                 @default(0)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  contract Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tiers    ContractOfferTier[]

  @@index([contractId])
  @@map("ct_contract_special_offer")
}

model ContractOfferTier {
  id             String   @id @default(cuid())
  offerId        String
  thresholdValue Int      // advance days (EBD) or min nights (Long Stay)
  discountType   SupplementValueType @default(FIXED)
  discountValue  Decimal  @db.Decimal(12, 4)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  offer ContractSpecialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("ct_contract_offer_tier")
}

model ContractSeasonSpo {
  id              String   @id @default(cuid())
  contractId      String
  spoType         String   // "RATE_OVERRIDE" | "BOOKING_WINDOW" | "PERCENTAGE"

  dateFrom        DateTime  @db.Date
  dateTo          DateTime  @db.Date

  // Rate Override columns
  basePp          Decimal?  @db.Decimal(12, 4)
  sglSup          Decimal?  @db.Decimal(12, 4)
  thirdAdultRed   Decimal?  @db.Decimal(12, 4)
  firstChildPct   Decimal?  @db.Decimal(12, 4)
  secondChildPct  Decimal?  @db.Decimal(12, 4)

  // Booking Window fields
  bookFrom        DateTime? @db.Date
  bookTo          DateTime? @db.Date

  // Value (BOOKING_WINDOW and PERCENTAGE)
  value           Decimal?  @db.Decimal(12, 4)
  valueType       String?   // "FIXED" | "PERCENTAGE"

  active          Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([contractId, spoType])
  @@map("ct_contract_season_spo")
}

enum AllocationBasis {
  FREESALE
  ON_REQUEST
  COMMITMENT
  ALLOCATION
}

model ContractAllotment {
  id         String          @id @default(cuid())
  contractId String
  seasonId   String?
  roomTypeId String
  basis      AllocationBasis @default(ALLOCATION)
  totalRooms Int
  freeSale   Boolean         @default(false)
  soldRooms  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  contract Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  season   ContractSeason? @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  roomType HotelRoomType   @relation(fields: [roomTypeId], references: [id])

  @@unique([contractId, seasonId, roomTypeId])
  @@index([contractId])
  @@map("ct_contract_allotment")
}

model ContractStopSale {
  id         String    @id @default(cuid())
  contractId String
  roomTypeId String?
  dateFrom   DateTime  @db.Date
  dateTo     DateTime  @db.Date
  reason     String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  contract Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  roomType HotelRoomType? @relation(fields: [roomTypeId], references: [id])

  @@index([contractId])
  @@index([contractId, dateFrom, dateTo])
  @@map("ct_contract_stop_sale")
}

model ContractMarketingContribution {
  id         String   @id @default(cuid())
  contractId String
  marketId   String?
  seasonId   String?
  valueType  SupplementValueType @default(FIXED)
  value      Decimal  @db.Decimal(12, 4)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contract Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  market   Market?         @relation(fields: [marketId], references: [id])
  season   ContractSeason? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("ct_contract_marketing_contribution")
}

model ContractChildPolicy {
  id              String           @id @default(cuid())
  contractId      String
  category        ChildAgeCategory
  ageFrom         Int
  ageTo           Int
  label           String
  freeInSharing   Boolean          @default(false)
  maxFreePerRoom  Int              @default(0)
  extraBedAllowed Boolean          @default(true)
  mealsIncluded    Boolean          @default(false)
  chargePercentage Int              @default(100)
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, category])
  @@index([contractId])
  @@map("ct_contract_child_policy")
}

model ContractCancellationPolicy {
  id          String   @id @default(cuid())
  contractId  String
  daysBefore  Int
  chargeType  String   @default("PERCENTAGE")
  chargeValue Decimal  @db.Decimal(12, 4)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("ct_contract_cancellation_policy")
}

// ─── Markets ────────────────────────────────────────────────

model Market {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  code       String
  countryIds String[] // array of country IDs this market covers
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contracts               ContractMarket[]
  bookings                Booking[]
  tourOperators           TourOperator[]
  markupRules             MarkupRule[]
  marketingContributions  ContractMarketingContribution[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("ct_market")
}

model ContractMarket {
  id         String   @id @default(cuid())
  contractId String
  marketId   String
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  market   Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([contractId, marketId])
  @@index([contractId])
  @@map("ct_contract_market")
}

// ============================================================================
// TOUR OPERATOR — CONTRACT & HOTEL ASSIGNMENTS
// ============================================================================

model TourOperator {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  code          String
  contactPerson String?
  email         String?
  phone         String?
  countryId     String?
  marketId      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country            Country?               @relation("TOCountry", fields: [countryId], references: [id])
  market             Market?                @relation(fields: [marketId], references: [id])
  contractAssignments ContractTourOperator[]
  hotelAssignments    HotelTourOperator[]
  markupRules         MarkupRule[]
  tariffs             Tariff[]
  apiIntegration      ApiIntegration?
  bookings            Booking[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("ct_tour_operator")
}

model ContractTourOperator {
  id             String   @id @default(cuid())
  contractId     String
  tourOperatorId String
  assignedAt     DateTime @default(now())
  notes          String?

  contract     Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tourOperator TourOperator @relation(fields: [tourOperatorId], references: [id], onDelete: Cascade)

  @@unique([contractId, tourOperatorId])
  @@index([contractId])
  @@index([tourOperatorId])
  @@map("ct_contract_tour_operator")
}

model HotelTourOperator {
  id             String   @id @default(cuid())
  hotelId        String
  tourOperatorId String
  assignedAt     DateTime @default(now())
  notes          String?

  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  tourOperator TourOperator @relation(fields: [tourOperatorId], references: [id], onDelete: Cascade)

  @@unique([hotelId, tourOperatorId])
  @@index([hotelId])
  @@index([tourOperatorId])
  @@map("ct_hotel_tour_operator")
}

// ============================================================================
// MARKUP & TARIFF
// ============================================================================

enum MarkupType {
  PERCENTAGE
  FIXED_PER_NIGHT
  FIXED_PER_BOOKING
}

model MarkupRule {
  id            String     @id @default(cuid())
  companyId     String
  name          String
  markupType    MarkupType
  value         Decimal    @db.Decimal(12, 4)
  // Scope targets (optional — more specific = higher priority)
  contractId    String?
  hotelId       String?
  destinationId String?
  marketId      String?
  tourOperatorId String?
  priority      Int        @default(0)
  active        Boolean    @default(true)
  validFrom     DateTime?  @db.Date
  validTo       DateTime?  @db.Date
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract     Contract?     @relation(fields: [contractId], references: [id])
  hotel        Hotel?        @relation("MarkupRuleHotel", fields: [hotelId], references: [id])
  destination  Destination?  @relation(fields: [destinationId], references: [id])
  market       Market?       @relation(fields: [marketId], references: [id])
  tourOperator TourOperator? @relation(fields: [tourOperatorId], references: [id])
  tariffs      Tariff[]
  bookings     Booking[]

  @@index([companyId])
  @@map("ct_markup_rule")
}

model Tariff {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  contractId    String
  tourOperatorId String
  markupRuleId  String?
  currencyCode  String
  data          Json     // Full generated tariff data
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract     Contract      @relation(fields: [contractId], references: [id])
  tourOperator TourOperator  @relation(fields: [tourOperatorId], references: [id])
  markupRule   MarkupRule?   @relation(fields: [markupRuleId], references: [id])

  @@index([companyId])
  @@index([contractId])
  @@index([tourOperatorId])
  @@map("ct_tariff")
}

// ============================================================================
// SPECIAL MEALS (Gala Dinners)
// ============================================================================

enum SpecialMealOccasion {
  NYE
  CHRISTMAS
  EASTER
  CUSTOM
}

model ContractSpecialMeal {
  id            String              @id @default(cuid())
  contractId    String
  occasion      SpecialMealOccasion
  customName    String?             // For CUSTOM occasion
  dateFrom      DateTime            @db.Date
  dateTo        DateTime            @db.Date
  mandatory     Boolean             @default(true)
  adultPrice    Decimal             @db.Decimal(12, 2)
  childPrice    Decimal?            @db.Decimal(12, 2)
  teenPrice     Decimal?            @db.Decimal(12, 2)
  infantPrice   Decimal?            @db.Decimal(12, 2)
  excludedMealBases String?         // comma-separated meal codes excluded (e.g. "AI,UAI")
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("ct_contract_special_meal")
}

// ============================================================================
// RATE VERIFICATION (Booking Simulator)
// ============================================================================

model RateVerification {
  id           String   @id @default(cuid())
  companyId    String
  contractId   String
  checkIn      DateTime @db.Date
  checkOut     DateTime @db.Date
  adults       Int      @default(2)
  children     Int      @default(0)
  childAges    Json?    // Array of ages
  bookingDate  DateTime? @db.Date
  resultData   Json     // Full simulation result
  warnings     Json?    // Array of warning strings
  status       String   @default("OK") // OK, WARNING, ERROR
  createdAt    DateTime @default(now())
  createdById  String?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("RateVerificationCreator", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([contractId])
  @@map("ct_rate_verification")
}

// ============================================================================
// CONTRACT COPY LOG
// ============================================================================

model ContractCopyLog {
  id                  String       @id @default(cuid())
  companyId           String
  sourceContractId    String
  targetContractId    String
  rateMode            CopyRateMode @default(FREEZE)
  ratePercent         Decimal?     @db.Decimal(8, 4)
  averageSourceIds    Json?        // Array of contract IDs for AVERAGE mode
  copiedEntities      Json?        // List of entity types copied
  dateShiftDays       Int?
  createdAt           DateTime     @default(now())
  createdById         String?

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceContract Contract  @relation("CopyLogSource", fields: [sourceContractId], references: [id])
  targetContract Contract  @relation("CopyLogTarget", fields: [targetContractId], references: [id])
  createdBy      User?     @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([sourceContractId])
  @@index([targetContractId])
  @@map("ct_contract_copy_log")
}

// ============================================================================
// CONTRACT AUDIT LOG
// ============================================================================

model ContractAuditLog {
  id         String   @id @default(cuid())
  contractId String
  action     String   // CREATE, UPDATE, DELETE, POST, PUBLISH, RESET_DRAFT, CLONE
  entity     String   // CONTRACT, SEASON, ROOM_TYPE, MEAL_BASIS, BASE_RATE, SUPPLEMENT, OFFER, ALLOTMENT, SPO, CHILD_POLICY, CANCELLATION
  entityId   String?
  summary    String   // Human-readable summary
  userId     String
  userName   String   // Denormalized for display
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@map("ct_contract_audit_log")
}

// ============================================================================
// API KEYS
// ============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  permissions String[]  @default(["contracting:read"])
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company          @relation(fields: [companyId], references: [id])
  integration ApiIntegration?

  @@index([companyId])
  @@index([keyHash])
}

// ============================================================================
// API INTEGRATIONS
// ============================================================================

model ApiIntegration {
  id              String   @id @default(cuid())
  companyId       String
  tourOperatorId  String   @unique
  apiKeyId        String   @unique
  webhookUrl      String?
  webhookSecret   String?
  active          Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tourOperator     TourOperator          @relation(fields: [tourOperatorId], references: [id], onDelete: Cascade)
  apiKey           ApiKey                @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  hotels           ApiIntegrationHotel[]
  webhookDeliveries WebhookDelivery[]

  @@unique([companyId, tourOperatorId])
  @@index([companyId])
}

model ApiIntegrationHotel {
  id               String   @id @default(cuid())
  apiIntegrationId String
  hotelId          String
  createdAt        DateTime @default(now())

  integration ApiIntegration @relation(fields: [apiIntegrationId], references: [id], onDelete: Cascade)
  hotel       Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([apiIntegrationId, hotelId])
  @@index([apiIntegrationId])
  @@index([hotelId])
}

model WebhookDelivery {
  id               String   @id @default(cuid())
  apiIntegrationId String
  event            String
  payload          Json
  url              String
  httpStatus       Int?
  responseBody     String?  @db.Text
  attempts         Int      @default(0)
  lastAttemptAt    DateTime?
  success          Boolean  @default(false)
  error            String?  @db.Text
  createdAt        DateTime @default(now())

  integration ApiIntegration @relation(fields: [apiIntegrationId], references: [id], onDelete: Cascade)

  @@index([apiIntegrationId])
  @@index([event])
  @@index([createdAt])
}

// ============================================================================
// RESERVATIONS MODULE — Enums
// ============================================================================

enum BookingStatus {
  NEW_BOOKING
  DRAFT
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
  PENDING_APPROVAL
}

enum BookingSource {
  DIRECT
  TOUR_OPERATOR
  API
}

enum VoucherStatus {
  ISSUED
  USED
  CANCELLED
}

enum BookingPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum GuestType {
  LEAD
  ADDITIONAL
  CHILD
}

enum PartnerBookingStatus {
  NEW_BOOKING
  SENT
  CONFIRMED
  REGRET
  STOP_SALE
  CANCELLED
}

enum RoomOccupancy {
  SINGLE
  DOUBLE
  TRIPLE
  FAMILY
}

enum HotelPaymentMethod {
  CASH
  VOUCHER
}

// ============================================================================
// RESERVATIONS MODULE — Models
// ============================================================================

model Guest {
  id             String    @id @default(cuid())
  companyId      String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  mobile         String?
  nationality    String?
  passportNo     String?
  passportExpiry DateTime? @db.Date
  dateOfBirth    DateTime? @db.Date
  gender         String?
  address        String?
  city           String?
  countryId      String?
  notes          String?   @db.Text
  partnerId      String?
  isVip          Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country       Country? @relation("GuestCountry", fields: [countryId], references: [id])
  partner       Partner? @relation(fields: [partnerId], references: [id])

  bookingGuests BookingGuest[]

  @@index([companyId])
  @@index([companyId, email])
  @@index([companyId, passportNo])
  @@index([companyId, lastName, firstName])
  @@map("rv_guest")
}

model Booking {
  id                 String              @id @default(cuid())
  companyId          String
  code               String
  status             BookingStatus       @default(NEW_BOOKING)
  source             BookingSource       @default(DIRECT)

  // Hotel & Contract
  hotelId            String
  contractId         String?
  tourOperatorId     String?
  seasonId           String?
  marketId           String?

  // Dates
  checkIn            DateTime            @db.Date
  checkOut           DateTime            @db.Date
  nights             Int

  // Rates
  currencyId         String
  rateBasis          String?
  buyingTotal        Decimal             @default(0) @db.Decimal(12, 4)
  sellingTotal       Decimal             @default(0) @db.Decimal(12, 4)
  manualRate         Boolean             @default(false)

  // Markup tracking
  markupRuleId       String?
  markupType         String?
  markupValue        Decimal?            @db.Decimal(12, 4)
  markupAmount       Decimal             @default(0) @db.Decimal(12, 4)

  // Payment tracking
  paymentStatus      BookingPaymentStatus @default(UNPAID)
  totalPaid          Decimal             @default(0) @db.Decimal(12, 4)
  balanceDue         Decimal             @default(0) @db.Decimal(12, 4)

  // Lead guest shortcut
  leadGuestName      String?
  leadGuestEmail     String?
  leadGuestPhone     String?

  // Partner booking statuses
  htlBookingStatus   PartnerBookingStatus?
  toBookingStatus    PartnerBookingStatus?

  // Flight — Arrival
  arrivalFlightNo    String?
  arrivalTime        String?
  arrivalOriginApt   String?
  arrivalDestApt     String?
  arrivalTerminal    String?

  // Flight — Departure
  departFlightNo     String?
  departTime         String?
  departOriginApt    String?
  departDestApt      String?
  departTerminal     String?

  // Room summary
  roomOccupancy      RoomOccupancy?
  noOfRooms          Int                 @default(1)
  adults             Int                 @default(2)
  children           Int                 @default(0)
  infants            Int                 @default(0)

  // Guest names (stored as JSON array)
  guestNames         Json?

  // Child DOBs
  childDob1          DateTime?           @db.Date
  childDob2          DateTime?           @db.Date

  // Hotel payment
  hotelPaymentMethod HotelPaymentMethod?
  paymentOptionDate  DateTime?           @db.Date

  // Misc
  specialRequests    String?             @db.Text
  internalNotes      String?             @db.Text
  externalRef        String?
  bookingNotes       String?             @db.Text
  meetAssistVisa     Boolean             @default(false)
  apiIntegrationId   String?

  // Lock
  isLocked           Boolean             @default(false)
  lockedAt           DateTime?
  lockedById         String?

  // Workflow
  confirmedAt        DateTime?
  confirmedById      String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?             @db.Text
  checkedInAt        DateTime?
  checkedInById      String?
  checkedOutAt       DateTime?
  checkedOutById     String?

  // Stop-sale override approval
  stopSaleOverride   Boolean              @default(false)
  approvalStatus     String?              // PENDING, APPROVED, REJECTED
  approvedById       String?
  approvedAt         DateTime?
  approvalNote       String?              @db.Text

  // Audit
  createdById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hotel          Hotel            @relation(fields: [hotelId], references: [id])
  contract       Contract?        @relation(fields: [contractId], references: [id])
  tourOperator   TourOperator?    @relation(fields: [tourOperatorId], references: [id])
  season         ContractSeason?  @relation(fields: [seasonId], references: [id])
  market         Market?          @relation(fields: [marketId], references: [id])
  currency       Currency         @relation("BookingCurrency", fields: [currencyId], references: [id])
  markupRule     MarkupRule?      @relation(fields: [markupRuleId], references: [id])
  createdBy      User?            @relation("BookingCreator", fields: [createdById], references: [id])
  confirmedBy    User?            @relation("BookingConfirmer", fields: [confirmedById], references: [id])
  cancelledBy    User?            @relation("BookingCanceller", fields: [cancelledById], references: [id])
  checkedInBy    User?            @relation("BookingCheckIn", fields: [checkedInById], references: [id])
  checkedOutBy   User?            @relation("BookingCheckOut", fields: [checkedOutById], references: [id])
  lockedBy       User?            @relation("BookingLocker", fields: [lockedById], references: [id])
  approvedBy     User?            @relation("BookingApprover", fields: [approvedById], references: [id])

  rooms          BookingRoom[]
  guests         BookingGuest[]
  payments       BookingPayment[]
  vouchers       Voucher[]
  timeline       BookingTimeline[]
  notifications  Notification[]

  // Traffic relations
  trafficJobs    TtTrafficJob[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, hotelId])
  @@index([companyId, tourOperatorId])
  @@index([companyId, checkIn])
  @@index([hotelId, checkIn, checkOut])
  @@index([contractId])
  @@map("rv_booking")
}

model BookingRoom {
  id                  String   @id @default(cuid())
  bookingId           String
  roomTypeId          String
  mealBasisId         String
  roomIndex           Int      @default(1)

  // Occupancy
  adults              Int      @default(2)
  children            Int      @default(0)
  infants             Int      @default(0)
  extraBed            Boolean  @default(false)

  // Per-room rate (buying)
  buyingRatePerNight  Decimal  @default(0) @db.Decimal(12, 4)
  buyingTotal         Decimal  @default(0) @db.Decimal(12, 4)

  // Per-room rate (selling)
  sellingRatePerNight Decimal  @default(0) @db.Decimal(12, 4)
  sellingTotal        Decimal  @default(0) @db.Decimal(12, 4)

  // Rate breakdown (stored as JSON for audit)
  rateBreakdown       Json?

  specialRequests     String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  booking   Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType  HotelRoomType  @relation("BookingRoomType", fields: [roomTypeId], references: [id])
  mealBasis HotelMealBasis @relation("BookingMealBasis", fields: [mealBasisId], references: [id])

  guests    BookingGuest[]

  @@index([bookingId])
  @@map("rv_booking_room")
}

model BookingGuest {
  id            String    @id @default(cuid())
  bookingId     String
  bookingRoomId String
  guestId       String
  guestType     GuestType @default(ADDITIONAL)
  isLeadGuest   Boolean   @default(false)

  // Child-specific
  childCategory String?
  childAge      Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingRoom BookingRoom @relation(fields: [bookingRoomId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId], references: [id])

  @@index([bookingId])
  @@index([bookingRoomId])
  @@index([guestId])
  @@map("rv_booking_guest")
}

model BookingPayment {
  id            String   @id @default(cuid())
  bookingId     String
  amount        Decimal  @db.Decimal(12, 4)
  currencyId    String
  method        String
  reference     String?
  notes         String?  @db.Text
  paidAt        DateTime @db.Date
  isRefund      Boolean  @default(false)

  // Finance integration
  finPaymentId  String?  @unique
  finMoveId     String?  @unique

  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  currency  Currency @relation("BookingPaymentCurrency", fields: [currencyId], references: [id])
  createdBy User     @relation("BookingPaymentCreator", fields: [createdById], references: [id])

  @@index([bookingId])
  @@map("rv_booking_payment")
}

model Voucher {
  id          String        @id @default(cuid())
  companyId   String
  code        String
  bookingId   String
  status      VoucherStatus @default(ISSUED)
  issuedAt    DateTime      @default(now())
  usedAt      DateTime?
  cancelledAt DateTime?
  notes       String?       @db.Text

  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy User    @relation("VoucherCreator", fields: [createdById], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([bookingId])
  @@map("rv_voucher")
}

model BookingTimeline {
  id        String   @id @default(cuid())
  bookingId String
  action    String
  details   String?  @db.Text
  userId    String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation("TimelineUser", fields: [userId], references: [id])

  @@index([bookingId])
  @@map("rv_booking_timeline")
}

model Notification {
  id          String    @id @default(cuid())
  companyId   String
  recipientId String
  type        String    // e.g. "STOP_SALE_APPROVAL"
  title       String
  message     String    @db.Text
  link        String?   // URL to navigate to
  bookingId   String?
  read        Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipient User     @relation("NotificationRecipient", fields: [recipientId], references: [id])
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
  @@index([companyId])
  @@map("sys_notification")
}

// ============================================================================
// TRAFFIC & TRANSPORT MODULE — Enums
// ============================================================================

enum TtServiceType {
  ARR
  DEP
  ARR_DEP
  EXCURSION
  INTER_HOTEL
  CITY_TOUR
  PRIVATE_HIRE
  AIRPORT_MEET
  VIP
  SHUTTLE
  CHARTER
  OTHER
}

enum TtJobStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TtVehicleOwnership {
  OWNED
  RENTED
  CONTRACTED
}

enum TtVehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum TtDriverStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum TtBookingStatus {
  QUOTE
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum TtAssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TtPortalJobStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  AT_PICKUP
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

enum TtComplianceType {
  INSURANCE
  REGISTRATION
  INSPECTION
  PERMIT
  OTHER
}

enum TtPriceType {
  PER_VEHICLE
  PER_PERSON
  PER_ZONE
  FLAT_RATE
}

// ============================================================================
// TRAFFIC & TRANSPORT MODULE — Shared Model: Airport
// ============================================================================

model Airport {
  id        String  @id @default(cuid())
  code      String  @unique // IATA 3-letter code
  name      String
  countryId String
  latitude  Float?
  longitude Float?
  timezone  String?
  isActive  Boolean @default(true)

  country           Country          @relation(fields: [countryId], references: [id])
  ttJobsPickup      TtTrafficJob[]   @relation("TtJobPickupAirport")
  ttJobsDropoff     TtTrafficJob[]   @relation("TtJobDropoffAirport")
  ttFlightsArr      TtTrafficFlight[] @relation("TtFlightArrAirport")
  ttFlightsDep      TtTrafficFlight[] @relation("TtFlightDepAirport")

  @@index([code])
  @@index([countryId])
}

// ============================================================================
// TRAFFIC & TRANSPORT MODULE — Models
// ============================================================================

model TtZone {
  id          String   @id @default(cuid())
  companyId   String
  cityId      String
  name        String
  code        String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  city              City                  @relation(fields: [cityId], references: [id])
  repZones          TtRepZone[]
  priceItemsFrom    TtPriceItem[]         @relation("TtPriceFromZone")
  priceItemsTo      TtPriceItem[]         @relation("TtPriceToZone")
  trafficJobs       TtTrafficJob[]

  @@unique([companyId, cityId, code])
  @@index([companyId])
  @@index([cityId])
  @@map("tt_zone")
}

model TtVehicleType {
  id                String   @id @default(cuid())
  companyId         String
  name              String
  code              String
  capacity          Int      @default(4)
  luggageCapacity   Int?
  description       String?
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicles             TtVehicle[]
  priceItems           TtPriceItem[]
  supplierTripPrices   TtSupplierTripPrice[]
  trafficJobs          TtTrafficJob[]
  guestBookings        TtGuestBooking[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("tt_vehicle_type")
}

model TtVehicle {
  id            String             @id @default(cuid())
  companyId     String
  vehicleTypeId String
  supplierId    String?
  plateNumber   String
  make          String?
  model         String?
  year          Int?
  color         String?
  vinNumber     String?
  ownership     TtVehicleOwnership @default(OWNED)
  status        TtVehicleStatus    @default(ACTIVE)
  notes         String?            @db.Text
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleType  TtVehicleType        @relation(fields: [vehicleTypeId], references: [id])
  supplier     Partner?             @relation(fields: [supplierId], references: [id])
  compliances  TtVehicleCompliance[]
  driverVehicles TtDriverVehicle[]
  assignments  TtTrafficAssignment[]

  @@unique([companyId, plateNumber])
  @@index([companyId])
  @@index([vehicleTypeId])
  @@index([supplierId])
  @@map("tt_vehicle")
}

model TtVehicleCompliance {
  id           String           @id @default(cuid())
  companyId    String
  vehicleId    String
  type         TtComplianceType
  documentRef  String?
  issueDate    DateTime?        @db.Date
  expiryDate   DateTime         @db.Date
  notes        String?          @db.Text
  fileUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle TtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([vehicleId])
  @@index([expiryDate])
  @@map("tt_vehicle_compliance")
}

model TtDriver {
  id            String         @id @default(cuid())
  companyId     String
  userId        String         @unique
  licenseNumber String?
  licenseExpiry DateTime?      @db.Date
  phone         String?
  status        TtDriverStatus @default(ACTIVE)
  notes         String?        @db.Text
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id])
  driverVehicles TtDriverVehicle[]
  assignments    TtTrafficAssignment[]

  @@index([companyId])
  @@index([userId])
  @@map("tt_driver")
}

model TtDriverVehicle {
  id         String   @id @default(cuid())
  companyId  String
  driverId   String
  vehicleId  String
  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())

  company Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver  TtDriver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle TtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([driverId, vehicleId])
  @@index([companyId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("tt_driver_vehicle")
}

model TtRep {
  id        String   @id @default(cuid())
  companyId String
  userId    String   @unique
  phone     String?
  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id])
  repZones   TtRepZone[]
  assignments TtTrafficAssignment[]

  @@index([companyId])
  @@index([userId])
  @@map("tt_rep")
}

model TtRepZone {
  id        String   @id @default(cuid())
  companyId String
  repId     String
  zoneId    String
  assignedAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rep     TtRep   @relation(fields: [repId], references: [id], onDelete: Cascade)
  zone    TtZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([repId, zoneId])
  @@index([companyId])
  @@index([repId])
  @@index([zoneId])
  @@map("tt_rep_zone")
}

model TtPriceItem {
  id            String      @id @default(cuid())
  companyId     String
  vehicleTypeId String
  fromZoneId    String?
  toZoneId      String?
  priceType     TtPriceType @default(PER_VEHICLE)
  price         Decimal     @db.Decimal(12, 4)
  currencyId    String
  serviceType   TtServiceType?
  description   String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleType TtVehicleType @relation(fields: [vehicleTypeId], references: [id])
  fromZone    TtZone?       @relation("TtPriceFromZone", fields: [fromZoneId], references: [id])
  toZone      TtZone?       @relation("TtPriceToZone", fields: [toZoneId], references: [id])
  currency    Currency      @relation(fields: [currencyId], references: [id])
  overrides   TtPartnerPriceOverride[]

  @@index([companyId])
  @@index([vehicleTypeId])
  @@index([fromZoneId])
  @@index([toZoneId])
  @@map("tt_price_item")
}

model TtPartnerPriceOverride {
  id          String  @id @default(cuid())
  companyId   String
  partnerId   String
  priceItemId String
  price       Decimal @db.Decimal(12, 4)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner   Partner     @relation(fields: [partnerId], references: [id])
  priceItem TtPriceItem @relation(fields: [priceItemId], references: [id], onDelete: Cascade)

  @@unique([partnerId, priceItemId])
  @@index([companyId])
  @@index([partnerId])
  @@index([priceItemId])
  @@map("tt_partner_price_override")
}

model TtSupplierTripPrice {
  id            String  @id @default(cuid())
  companyId     String
  supplierId    String
  vehicleTypeId String
  routeDesc     String? // Free-text route description
  price         Decimal @db.Decimal(12, 4)
  currencyId    String
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Partner       @relation(fields: [supplierId], references: [id])
  vehicleType TtVehicleType @relation(fields: [vehicleTypeId], references: [id])
  currency    Currency      @relation(fields: [currencyId], references: [id])

  @@index([companyId])
  @@index([supplierId])
  @@index([vehicleTypeId])
  @@map("tt_supplier_trip_price")
}

// ── Traffic Job (Core) ──

model TtTrafficJob {
  id              String        @id @default(cuid())
  companyId       String
  code            String
  serviceType     TtServiceType
  status          TtJobStatus   @default(PENDING)
  vehicleTypeId   String?

  // Date & time
  serviceDate     DateTime      @db.Date
  pickupTime      String?       // HH:mm
  dropoffTime     String?

  // Pickup location (one of airport/hotel/free-text)
  pickupAirportId  String?
  pickupHotelId    String?
  pickupAddress    String?

  // Dropoff location
  dropoffAirportId String?
  dropoffHotelId   String?
  dropoffAddress   String?

  // Zone & pricing
  zoneId           String?
  partnerId        String?
  bookingId        String?
  flightId         String?

  // Passenger info
  paxCount         Int          @default(1)
  leadPassenger    String?
  passengerPhone   String?
  passengerNotes   String?      @db.Text

  // Pricing
  currencyId       String?
  price            Decimal      @default(0) @db.Decimal(12, 4)
  cost             Decimal      @default(0) @db.Decimal(12, 4)

  // Dispatch
  dispatchLockedAt DateTime?
  signImageUrl     String?

  // Audit
  createdById      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleType    TtVehicleType?        @relation(fields: [vehicleTypeId], references: [id])
  pickupAirport  Airport?              @relation("TtJobPickupAirport", fields: [pickupAirportId], references: [id])
  pickupHotel    Hotel?                @relation("TtJobPickupHotel", fields: [pickupHotelId], references: [id])
  dropoffAirport Airport?              @relation("TtJobDropoffAirport", fields: [dropoffAirportId], references: [id])
  dropoffHotel   Hotel?                @relation("TtJobDropoffHotel", fields: [dropoffHotelId], references: [id])
  zone           TtZone?               @relation(fields: [zoneId], references: [id])
  partner        Partner?              @relation(fields: [partnerId], references: [id])
  booking        Booking?              @relation(fields: [bookingId], references: [id])
  flight         TtTrafficFlight?      @relation(fields: [flightId], references: [id])
  currency       Currency?             @relation("TtJobCurrency", fields: [currencyId], references: [id])
  createdBy      User?                 @relation("TtJobCreator", fields: [createdById], references: [id])
  assignments    TtTrafficAssignment[]
  statusLogs     TtStatusChangeLog[]
  noShowEvidence TtNoShowEvidence[]
  operationalCosts TtOperationalCost[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, serviceDate])
  @@index([companyId, status])
  @@index([partnerId])
  @@index([bookingId])
  @@index([flightId])
  @@map("tt_traffic_job")
}

model TtTrafficFlight {
  id            String   @id @default(cuid())
  companyId     String
  flightNumber  String
  airlineCode   String?
  arrAirportId  String?
  depAirportId  String?
  arrTime       String?  // HH:mm
  depTime       String?
  flightDate    DateTime @db.Date
  terminal      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  arrAirport Airport?  @relation("TtFlightArrAirport", fields: [arrAirportId], references: [id])
  depAirport Airport?  @relation("TtFlightDepAirport", fields: [depAirportId], references: [id])
  jobs       TtTrafficJob[]

  @@index([companyId])
  @@index([companyId, flightDate])
  @@index([flightNumber])
  @@map("tt_traffic_flight")
}

model TtTrafficAssignment {
  id          String             @id @default(cuid())
  companyId   String
  jobId       String
  vehicleId   String?
  driverId    String?
  repId       String?
  status      TtAssignmentStatus @default(PENDING)
  notes       String?            @db.Text
  assignedAt  DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job     TtTrafficJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  vehicle TtVehicle?   @relation(fields: [vehicleId], references: [id])
  driver  TtDriver?    @relation(fields: [driverId], references: [id])
  rep     TtRep?       @relation(fields: [repId], references: [id])

  @@index([companyId])
  @@index([jobId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([repId])
  @@map("tt_traffic_assignment")
}

model TtStatusChangeLog {
  id         String   @id @default(cuid())
  jobId      String
  fromStatus String
  toStatus   String
  changedBy  String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  job TtTrafficJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("tt_status_change_log")
}

model TtNoShowEvidence {
  id        String   @id @default(cuid())
  jobId     String
  imageUrl  String
  latitude  Float?
  longitude Float?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  job TtTrafficJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("tt_no_show_evidence")
}

model TtGuestBooking {
  id            String          @id @default(cuid())
  companyId     String
  code          String
  status        TtBookingStatus @default(QUOTE)
  vehicleTypeId String
  serviceType   TtServiceType   @default(ARR)
  serviceDate   DateTime        @db.Date
  pickupTime    String?
  pickupAddress String?
  dropoffAddress String?
  paxCount      Int             @default(1)
  guestName     String
  guestEmail    String?
  guestPhone    String?
  currencyId    String
  quotedPrice   Decimal         @default(0) @db.Decimal(12, 4)
  paidAmount    Decimal         @default(0) @db.Decimal(12, 4)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleType TtVehicleType    @relation(fields: [vehicleTypeId], references: [id])
  currency    Currency         @relation("TtGuestBookingCurrency", fields: [currencyId], references: [id])
  payments    TtGuestPayment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@map("tt_guest_booking")
}

model TtGuestPayment {
  id             String   @id @default(cuid())
  guestBookingId String
  amount         Decimal  @db.Decimal(12, 4)
  method         String   // CASH, CARD, ONLINE
  reference      String?
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  guestBooking TtGuestBooking @relation(fields: [guestBookingId], references: [id], onDelete: Cascade)

  @@index([guestBookingId])
  @@map("tt_guest_payment")
}

model TtOperationalCost {
  id         String   @id @default(cuid())
  companyId  String
  jobId      String
  costType   String   // DRIVER_FEE, REP_FEE, SUPPLIER_COST, FUEL, TOLL, OTHER
  amount     Decimal  @db.Decimal(12, 4)
  currencyId String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job      TtTrafficJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  currency Currency     @relation("TtOpCostCurrency", fields: [currencyId], references: [id])

  @@index([companyId])
  @@index([jobId])
  @@map("tt_operational_cost")
}

model TtSettings {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  defaultCurrencyId     String?
  dispatchLockHours     Int      @default(48)
  enableDriverPortal    Boolean  @default(false)
  enableRepPortal       Boolean  @default(false)
  enableSupplierPortal  Boolean  @default(false)
  enableGuestBookings   Boolean  @default(false)
  whatsappEnabled       Boolean  @default(false)
  pushEnabled           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("tt_settings")
}

model TtPushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String   @default("web") // web, android, ios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("tt_push_token")
}
